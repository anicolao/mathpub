{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema", "project"],
  "properties": {
    "schema": {"const": 1},
    "project": {"type": "string", "pattern": "^[a-z0-9]+([.-][a-z0-9]+)*$"},
    "question_roots": {"type": "array", "items": {"type": "string"}},
    "publication_roots": {"type": "array", "items": {"type": "string"}},
    "profile_roots": {"type": "array", "items": {"type": "string"}},
    "build_dir": {"type": "string"},
    "default_profile": {"type": "string"},
    "generation": {"type": "object"},
    "tex": {"type": "object"}
  },
  "additionalProperties": false
}
